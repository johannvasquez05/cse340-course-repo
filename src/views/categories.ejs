<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Available Service Categories</h2>

        <ul class="category-list">
            <% categories.forEach(category=> { %>
                <li>
                    <strong>
                        <%= category.name %>
                    </strong>
                </li>
                <% }) %>
        </ul>
    </main>

    <%- include('partials/footer') %>