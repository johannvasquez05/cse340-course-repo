<%- include('partials/header') %>

    <main>
        <h1>
            <%= project.title %>
        </h1>

        <div>
            <p><strong>Date:</strong>
                <%= project.date %>
            </p>
            <p><strong>Location:</strong>
                <%= project.location %>
            </p>
            <p><strong>Partner Organization:</strong> <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a></p>

            <h2>About this Project</h2>
            <p>
                <%= project.description %>
            </p>
        </div>
    </main>

    <%- include('partials/footer') %>